# ============================================================
# Design Ops Navigator — Environment Variables
# Copy to .env in backend/ and .env.local in frontend/
# NEVER commit .env or .env.local
# ============================================================

# ── Google Cloud ─────────────────────────────────────────────
GOOGLE_API_KEY=                      # Gemini API key (AI Studio, for local dev)
GOOGLE_CLOUD_PROJECT=                # GCP project ID
GOOGLE_CLOUD_LOCATION=us-central1   # Region for Vertex AI
GOOGLE_GENAI_USE_VERTEXAI=false      # true in prod (Vertex AI), false in dev (AI Studio)
GOOGLE_APPLICATION_CREDENTIALS=     # Path to service account JSON (local only — optional if using gcloud auth)

# ── Firestore ─────────────────────────────────────────────────
FIRESTORE_DATABASE=(default)
FIRESTORE_COLLECTION_KNOWLEDGE=ux_knowledge
FIRESTORE_COLLECTION_SESSIONS=agent_sessions
FIRESTORE_COLLECTION_TRAJECTORIES=trajectories

# ── GCS ───────────────────────────────────────────────────────
GCS_BUCKET_SCREENSHOTS=design-ops-screenshots

# ── Figma ─────────────────────────────────────────────────────
FIGMA_ACCESS_TOKEN=                  # Personal Access Token from Figma Settings > Security

# ── CopilotKit ────────────────────────────────────────────────
COPILOTKIT_API_KEY=                  # From copilotkit.ai (optional for self-hosted)

# ── GitHub (optional — for Retriever to read team design repos) ──
GITHUB_TOKEN=                        # PAT with repo:read scope

# ── Team docs path (for filesystem MCP) ──────────────────────
TEAM_DOCS_PATH=./knowledge/team_docs  # Local; use GCS FUSE path in Cloud Run

# ── 21st.dev Magic MCP ───────────────────────────────────────
MAGIC_API_KEY=

# ── Frontend (Next.js) ────────────────────────────────────────
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000   # Cloud Run URL in prod
NEXT_PUBLIC_COPILOTKIT_KEY=                    # Same as COPILOTKIT_API_KEY if needed
